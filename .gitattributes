# Handle line endings automatically for files detected as text
# and perform LF normalization on checkin.
* text=auto

# Explicitly declare text files you want to always be normalized and shared
*.js text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
